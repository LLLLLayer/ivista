{
  "name": "ivista",
  "version": "1.0.4",
  "description": "CLI-first controls for iOS Simulator and iPhone/iPad through WebDriverAgent.",
  "type": "module",
  "bin": {
    "ivista": "./bin/ivista.mjs"
  },
  "files": [
    "bin",
    "src",
    "scripts",
    "plugins/ivista",
    "docs/README.md",
    "docs/cli.md",
    "docs/cli.zh-CN.md",
    "docs/troubleshooting.md",
    "docs/troubleshooting.zh-CN.md",
    "docs/development.md",
    "docs/development.zh-CN.md",
    ".agents/plugins/marketplace.json",
    ".claude-plugin/marketplace.json"
  ],
  "scripts": {
    "check": "find src bin -name '*.mjs' -print0 | xargs -0 -n1 node --check",
    "check:release": "node scripts/check-release.mjs",
    "doctor": "node bin/ivista.mjs doctor",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": [
    "ios",
    "simulator",
    "webdriveragent",
    "testing",
    "cli",
    "codex",
    "claude-code"
  ],
  "author": "iVista contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/LLLLLayer/ivista.git"
  },
  "homepage": "https://github.com/LLLLLayer/ivista"
}
